<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E3EDF6"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/logo_salud_app"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginTop="24dp"
        android:scaleType="centerInside"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/saludalogo" />

    <androidx.gridlayout.widget.GridLayout
        android:layout_width="401dp"
        android:layout_height="454dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="50dp"
        app:columnCount="2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logo_salud_app"
        app:layout_constraintVertical_bias="0.661"
        app:rowCount="3">

        <androidx.cardview.widget.CardView
            style="@style/SaludCardStyle"
            android:layout_width="185dp"
            android:layout_height="135dp"

            app:cardBackgroundColor="#FFFEFE"
            app:layout_column="1"
            app:layout_row="2" />

        <androidx.cardview.widget.CardView
            style="@style/SaludCardStyle"
            android:layout_width="185dp"
            android:layout_height="135dp"

            app:cardBackgroundColor="#FFFEFE"
            app:layout_column="1"
            app:layout_row="1" />

        <androidx.cardview.widget.CardView
            style="@style/SaludCardStyle"
            android:layout_width="189dp"
            android:layout_height="135dp"

            app:cardBackgroundColor="#FFFEFE"
            app:layout_column="0"
            app:layout_row="2" />

        <androidx.cardview.widget.CardView
            android:id="@+id/Peso_Card"
            style="@style/SaludCardStyle"
            android:layout_width="185dp"

            android:layout_height="135dp"
            app:cardBackgroundColor="#FFFEFE"
            app:layout_column="0"
            app:layout_row="0">

            <LinearLayout
                style="@style/SaludCardContentStyle"
                android:layout_width="189dp"
                android:layout_height="155dp"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageView4"
                    android:layout_width="119dp"
                    android:layout_height="57dp"
                    app:srcCompat="@drawable/ic_peso" />

                <TextView
                    android:id="@+id/textView2"
                    style="@style/TitleTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Seguimiento\nIntegral del Peso" />

                <TextView
                    android:id="@+id/textView3"
                    style="@style/SubtitleTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Registro, IMC, meta y progreso." />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            style="@style/SaludCardStyle"
            android:layout_width="188dp"
            android:layout_height="135dp"

            app:cardBackgroundColor="#FFFEFE"
            app:layout_column="0"
            app:layout_row="1" />

        <androidx.cardview.widget.CardView
            style="@style/SaludCardStyle"
            android:layout_width="185dp"
            android:layout_height="135dp"

            app:cardBackgroundColor="#FFFEFE"
            app:layout_column="1"
            app:layout_row="0">

            <LinearLayout
                style="@style/SaludCardContentStyle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageView5"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    app:srcCompat="@drawable/ic_presion" />

                <TextView
                    android:id="@+id/textView4"
                    style="@style/TitleTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Seguimiento\nIntegral del Peso" />

                <TextView
                    android:id="@+id/textView5"
                    style="@style/SubtitleTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="26dp"
                    android:text="Registro, sistolica, diastolica e historial." />
            </LinearLayout>
        </androidx.cardview.widget.CardView>


    </androidx.gridlayout.widget.GridLayout>
</androidx.constraintlayout.widget.ConstraintLayout>