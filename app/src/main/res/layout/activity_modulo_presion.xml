<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Encabezado azul -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A4375"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/ic_presion" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registro de Presión Arterial"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp" />
        </LinearLayout>

        <!-- Contenido principal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Tarjeta: Datos de la Medición -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Datos de la Medición"
                        android:textColor="#1A2D4A"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- Fila: Botón fecha + hora compacta -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <Button
                            android:id="@+id/btnFecha"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Seleccionar Fecha"
                            android:textSize="13sp"
                            android:backgroundTint="#1A4375"
                            android:textColor="#FFFFFF"
                            app:cornerRadius="8dp"
                            android:layout_marginEnd="12dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvHora"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00:00"
                                android:textColor="#1A2D4A"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="(AM/PM)"
                                android:textColor="#5E7A9D"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Fecha seleccionada -->
                    <TextView
                        android:id="@+id/txtFecha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fecha no seleccionada"
                        android:textColor="#5E7A9D"
                        android:textSize="13sp"
                        android:layout_marginBottom="16dp" />

                    <!-- Etiqueta TimePicker -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hora de la medición"
                        android:textColor="#5E7A9D"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp" />

                    <!-- TimePicker en modo spinner, 12h, colores oscuros para legibilidad -->
                    <TimePicker
                        android:id="@+id/timePicker"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:timePickerMode="spinner"
                        android:layout_gravity="center"
                        android:layout_marginBottom="16dp"
                        android:theme="@style/TimePickerSpinnerTheme" />

                    <!-- Etiqueta valores -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Valores de la medición"
                        android:textColor="#1A2D4A"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Fila NumberPickers -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp"
                        android:baselineAligned="false">

                        <!-- Sistólica -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SISTÓLICA"
                                android:textColor="#5E7A9D"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="(mmHg)"
                                android:textColor="#5E7A9D"
                                android:textSize="10sp"
                                android:layout_marginBottom="4dp" />

                            <NumberPicker
                                android:id="@+id/npSistolica"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:scaleX="1.1"
                                android:scaleY="1.1" />
                        </LinearLayout>

                        <!-- Diastólica -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DIASTÓLICA"
                                android:textColor="#5E7A9D"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="(mmHg)"
                                android:textColor="#5E7A9D"
                                android:textSize="10sp"
                                android:layout_marginBottom="4dp" />

                            <NumberPicker
                                android:id="@+id/npDiastolica"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:scaleX="1.1"
                                android:scaleY="1.1" />
                        </LinearLayout>

                        <!-- Pulso -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PULSO"
                                android:textColor="#5E7A9D"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="(BPM)"
                                android:textColor="#5E7A9D"
                                android:textSize="10sp"
                                android:layout_marginBottom="4dp" />

                            <NumberPicker
                                android:id="@+id/npPulso"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:scaleX="1.1"
                                android:scaleY="1.1" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Separador -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E8F0"
                        android:layout_marginBottom="12dp" />

                    <!-- Brazo utilizado -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Brazo Utilizado:"
                        android:textColor="#1A2D4A"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <RadioGroup
                        android:id="@+id/rgBrazo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rbIzquierdo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="#1A4375"
                            android:text="Brazo Izquierdo"
                            android:textColor="#1A2D4A"
                            android:textColorLink="#2196F3" />

                        <RadioButton
                            android:id="@+id/rbDerecho"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="#1A4375"
                            android:text="Brazo Derecho"
                            android:textColor="#1A2D4A"
                            android:textColorLink="#2196F3" />
                    </RadioGroup>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botón Analizar -->
            <Button
                android:id="@+id/btnAnalizar"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="ANALIZAR MEDICIÓN"
                android:textStyle="bold"
                android:textSize="15sp"
                android:backgroundTint="#1A4375"
                android:textColor="#FFFFFF"
                app:cornerRadius="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Tarjeta: Resumen y Análisis (oculta inicialmente) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardResultado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RESUMEN Y ANÁLISIS"
                        android:textColor="#1A2D4A"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Datos resumen -->
                    <TextView
                        android:id="@+id/txtResultado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#1A2D4A"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginBottom="12dp" />

                    <!-- Separador -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E8F0"
                        android:layout_marginBottom="10dp" />

                    <!-- Fila clasificación -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CLASIFICACIÓN:"
                            android:textColor="#1A2D4A"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="10dp" />

                        <TextView
                            android:id="@+id/tvClasificacion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="6dp" />
                    </LinearLayout>

                    <!-- Consejo -->
                    <TextView
                        android:id="@+id/tvConsejo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#5E7A9D"
                        android:textSize="12sp"
                        android:lineSpacingExtra="2dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
