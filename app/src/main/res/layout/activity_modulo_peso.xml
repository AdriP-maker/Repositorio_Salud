<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Control de Peso"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1A4375"
            android:layout_gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Etiqueta Edad -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Edad"
            android:textColor="#5E7A9D"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <!-- Campo Edad -->
        <EditText
            android:id="@+id/etEdad"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/input_round"
            android:paddingHorizontal="16dp"
            android:hint="Ej. 25"
            android:inputType="number"
            android:textColorHint="#AABCD4"
            android:textColor="#1A2D4A"
            android:layout_marginBottom="16dp" />

        <!-- Fila Peso + Switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Peso"
                android:textColor="#5E7A9D"
                android:textSize="13sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swPesoUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KG / LB"
                android:textColor="#1A4375"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Campo Peso -->
        <EditText
            android:id="@+id/etPeso"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/input_round"
            android:paddingHorizontal="16dp"
            android:hint="Peso (Kg)"
            android:inputType="numberDecimal"
            android:textColorHint="#AABCD4"
            android:textColor="#1A2D4A"
            android:layout_marginBottom="16dp" />

        <!-- Fila Estatura + Switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Estatura"
                android:textColor="#5E7A9D"
                android:textSize="13sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swEstaturaUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CM / IN"
                android:textColor="#1A4375"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Campo Estatura -->
        <EditText
            android:id="@+id/etEstatura"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/input_round"
            android:paddingHorizontal="16dp"
            android:hint="Estatura (cm)"
            android:inputType="numberDecimal"
            android:textColorHint="#AABCD4"
            android:textColor="#1A2D4A"
            android:layout_marginBottom="24dp" />

        <!-- Botón Calcular -->
        <Button
            android:id="@+id/btnCalcular"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="CALCULAR"
            android:textStyle="bold"
            android:backgroundTint="#1A4375"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp"
            android:layout_marginBottom="32dp" />

        <!-- CardView Resultados -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Fila métricas: IMC | PESO IDEAL | GRASA -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <!-- IMC -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IMC"
                            android:textColor="#5E7A9D"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvIMC"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#2E7D32"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- PESO IDEAL -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PESO IDEAL"
                            android:textColor="#5E7A9D"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvPesoIdeal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#2E7D32"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- GRASA -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GRASA"
                            android:textColor="#5E7A9D"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvGrasa"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#2E7D32"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Separador -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E8F0"
                    android:layout_marginBottom="12dp" />

                <!-- Clasificación -->
                <TextView
                    android:id="@+id/tvClasificacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Resultado"
                    android:gravity="center"
                    android:textColor="#1A4375"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
