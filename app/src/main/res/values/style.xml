<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="SaludCardStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:layout_margin">8dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">#FFFFFF</item>
    </style>
    <style name="SaludCardContentStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">12dp</item>
    </style>
    <style name="TitleTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#1A237E</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="SubtitleTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#757575</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Fuerza texto oscuro en el TimePicker spinner para que sea legible sobre fondo blanco -->
    <style name="TimePickerSpinnerTheme">
        <item name="android:textColorPrimary">#1A2D4A</item>
        <item name="android:textColorSecondary">#5E7A9D</item>
        <item name="colorControlNormal">#1A4375</item>
    </style>
</resources>
